<Page
    x:Class="PowerToolbox.Views.Pages.AdvancedSystemOptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:collection="using:System.Collections"
    xmlns:converter="using:PowerToolbox.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rootservice="using:PowerToolbox.Services.Root"
    xmlns:system="using:System"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <Thickness x:Key="BreadcrumbBarChevronPadding">6,0</Thickness>
        <x:Double x:Key="BreadcrumbBarChevronFontSize">16</x:Double>

        <TransitionCollection x:Name="SuppressNavigationTransitionCollection">
            <NavigationThemeTransition>
                <NavigationThemeTransition.DefaultNavigationTransitionInfo>
                    <SuppressNavigationTransitionInfo />
                </NavigationThemeTransition.DefaultNavigationTransitionInfo>
            </NavigationThemeTransition>
        </TransitionCollection>

        <TransitionCollection x:Name="LeftSlideNavigationTransitionCollection">
            <NavigationThemeTransition>
                <NavigationThemeTransition.DefaultNavigationTransitionInfo>
                    <SlideNavigationTransitionInfo Effect="FromLeft" />
                </NavigationThemeTransition.DefaultNavigationTransitionInfo>
            </NavigationThemeTransition>
        </TransitionCollection>

        <TransitionCollection x:Name="RightSlideNavigationTransitionCollection">
            <NavigationThemeTransition>
                <NavigationThemeTransition.DefaultNavigationTransitionInfo>
                    <SlideNavigationTransitionInfo Effect="FromRight" />
                </NavigationThemeTransition.DefaultNavigationTransitionInfo>
            </NavigationThemeTransition>
        </TransitionCollection>
    </Page.Resources>

    <Grid Margin="0,15,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="30,0,30,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <BreadcrumbBar
                Grid.Column="0"
                VerticalAlignment="Center"
                ItemClicked="{x:Bind OnItemClicked}"
                ItemsSource="{x:Bind BreadCollection}">

                <BreadcrumbBar.ItemTemplate>
                    <DataTemplate x:DataType="collection:DictionaryEntry">
                        <TextBlock FontSize="22" Text="{x:Bind system:Convert.ToString(Value)}" />
                    </DataTemplate>
                </BreadcrumbBar.ItemTemplate>
            </BreadcrumbBar>

            <Button
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                VerticalAlignment="Center"
                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeedAttention')}"
                Visibility="{x:Bind IsAdvancedSettingsInfoWarning, Mode=OneWay}">

                <InfoBadge
                    Width="18"
                    Height="18"
                    MaxWidth="9999"
                    MaxHeight="9999"
                    Padding="5,4,4,4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CautionIconInfoBadgeStyle}">

                    <InfoBadge.Resources>
                        <Thickness x:Key="IconInfoBadgeFontIconMargin">0</Thickness>
                    </InfoBadge.Resources>

                    <InfoBadge.IconSource>
                        <FontIconSource Glyph="&#xEA1F;" />
                    </InfoBadge.IconSource>
                </InfoBadge>

                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem
                            Click="{x:Bind OnRestartExplorerClicked}"
                            IsEnabled="{x:Bind converter:ValueConverterHelper.BooleanReverseConvert(IsRestarting), Mode=OneWay}"
                            Text="{x:Bind RestartExplorerText, Mode=OneWay}"
                            Visibility="{x:Bind IsRestartExplorerVisible, Mode=OneWay}">

                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xEC50;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>

                        <MenuFlyoutItem
                            Click="{x:Bind OnRestartPCClicked}"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('RestartPC')}"
                            Visibility="{x:Bind IsRestartPCVisible, Mode=OneWay}">

                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE977;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Frame
            x:Name="AdvancedSystemOptionsFrame"
            Grid.Row="1"
            Navigated="{x:Bind OnNavigated}"
            NavigationFailed="{x:Bind OnNavigationFailed}" />
    </Grid>
</Page>
