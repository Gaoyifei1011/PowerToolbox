<Page
    x:Class="PowerToolbox.Views.Pages.AdvancedSystemOptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rootservice="using:PowerToolbox.Services.Root"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="30,15,30,0"
            FontSize="22"
            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AdvancedSystemOptions')}" />

        <ScrollViewer
            Grid.Row="1"
            Padding="30,5,30,3"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">

            <StackPanel Margin="0,0,0,30">

                <!--  电源模式设置  -->
                <Grid
                    Height="60"
                    Margin="0,0,0,2"
                    Padding="16,0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Glyph="&#xE945;" />

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerModeSettings')}" />

                        <TextBlock
                            x:Name="PowerModeSettingsDescription"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerModeSettingsDescription')}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap">

                            <ToolTipService.ToolTip>
                                <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerModeSettingsDescription')}" Visibility="{x:Bind PowerModeSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                            </ToolTipService.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Width="32"
                        Height="32"
                        Margin="0,0,6,0"
                        Padding="0"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('ShowOptions')}">

                        <FontIcon FontSize="14" Glyph="&#xE712;" />

                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem Click="{x:Bind OnOpenSystemSettingsClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('OpenSystemSettings')}">
                                    <MenuFlyoutItem.Icon>
                                        <AnimatedIcon>
                                            <AnimatedIcon.Source>
                                                <animatedvisuals:AnimatedSettingsVisualSource />
                                            </AnimatedIcon.Source>
                                            <AnimatedIcon.FallbackIconSource>
                                                <FontIconSource Glyph="&#xE713;" />
                                            </AnimatedIcon.FallbackIconSource>
                                        </AnimatedIcon>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>

                                <MenuFlyoutItem Click="{x:Bind OnOpenControlPanelClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('OpenControlPanel')}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE70A;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Button
                        Grid.Column="3"
                        Width="32"
                        Height="32"
                        Padding="8"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('Change')}">

                        <AnimatedIcon>
                            <AnimatedIcon.Source>
                                <animatedvisuals:AnimatedChevronDownSmallVisualSource />
                            </AnimatedIcon.Source>
                            <AnimatedIcon.FallbackIconSource>
                                <FontIconSource Glyph="&#xE70D;" />
                            </AnimatedIcon.FallbackIconSource>
                        </AnimatedIcon>

                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <MenuFlyoutItem
                                    Click="{x:Bind OnChangePowerModeClicked}"
                                    Tag="EnergySaving"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('EnergySaving')}" />

                                <MenuFlyoutItem
                                    Click="{x:Bind OnChangePowerModeClicked}"
                                    Tag="Balance"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('Balance')}" />

                                <MenuFlyoutItem
                                    Click="{x:Bind OnChangePowerModeClicked}"
                                    Tag="HighPerformance"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('HighPerformance')}" />

                                <MenuFlyoutItem
                                    Click="{x:Bind OnChangePowerModeClicked}"
                                    Tag="OutstandingPerformance"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('OutstandingPerformance')}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <!--  用户账户控制设置  -->
                <Expander
                    Margin="0,0,0,2"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    IsExpanded="True">

                    <Expander.Header>
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                Grid.Column="0"
                                Margin="0,0,12,0"
                                FontSize="16"
                                Glyph="&#xF0EF;" />

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Vertical">

                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('UACSettings')}" />

                                <TextBlock
                                    x:Name="UACSettingsDescription"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('UACSettingsDescription')}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('UACSettingsDescription')}" Visibility="{x:Bind UACSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Expander.Header>

                    <StackPanel Padding="0">
                        <!--  用户账户控制通知模式  -->
                        <Grid
                            Height="52"
                            Padding="44,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyMode')}" />

                            <ComboBox
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayMember"
                                ItemsSource="{x:Bind NotifyModeList}"
                                SelectedItem="{x:Bind SelectedNotifyMode, Mode=OneWay}"
                                SelectionChanged="{x:Bind OnNotifyModeSelectionChanged}"
                                Style="{StaticResource ComboBoxStyle}" />
                        </Grid>

                        <MenuFlyoutSeparator />

                        <!--  用户账户控制通知模式说明  -->
                        <Grid Padding="44,5,16,8">
                            <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[0].SelectedValue), Mode=OneWay}">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AlwaysNotify')}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AlwaysNotifyDescription1')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="2"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AlwaysNotifyDescription2')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="3"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AlwaysNotifyDescription3')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="4"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('AlwaysNotifyDescription4')}"
                                    TextWrapping="Wrap" />
                            </Grid>

                            <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[1].SelectedValue), Mode=OneWay}">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('Notify')}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyDescription1')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="2"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyDescription2')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="3"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyDescription3')}"
                                    TextWrapping="Wrap" />
                            </Grid>

                            <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[2].SelectedValue), Mode=OneWay}">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyWithoutDimming')}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyWithoutDimmingDescription1')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="2"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyWithoutDimmingDescription2')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="3"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NotifyWithoutDimmingDescription3')}"
                                    TextWrapping="Wrap" />
                            </Grid>

                            <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[3].SelectedValue), Mode=OneWay}">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="16"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeverNotify')}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeverNotifyDescription1')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="2"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeverNotifyDescription2')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="3"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeverNotifyDescription3')}"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="4"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('NeverNotifyDescription4')}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!--  后台应用设置  -->
                <Grid
                    Height="60"
                    Margin="0,0,0,2"
                    Padding="16,0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Glyph="&#xEF1F;" />

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BackgroundAppsSettings')}" />

                        <TextBlock
                            x:Name="BackgroundAppsSettingsDescription"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BackgroundAppsSettingsDescription')}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap">

                            <ToolTipService.ToolTip>
                                <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BackgroundAppsSettingsDescription')}" Visibility="{x:Bind PowerModeSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                            </ToolTipService.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <ToggleSwitch
                        Grid.Column="2"
                        IsOn="{x:Bind IsBackgroundAppsTaskEnabled, Mode=OneWay}"
                        OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BackgroundAppsSettingsOffContent')}"
                        OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BackgroundAppsSettingsOnContent')}"
                        Style="{StaticResource ToggleSwitchStyle}"
                        Toggled="{x:Bind OnBackgroundAppsTaskToggled}" />
                </Grid>

                <!--  电源设置  -->
                <Expander
                    MinHeight="0"
                    Margin="0,0,0,2"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    IsExpanded="True">

                    <Expander.Header>
                        <Grid Height="60">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                Grid.Column="0"
                                Margin="0,0,12,0"
                                FontSize="16"
                                Glyph="&#xE7E8;" />

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Vertical">

                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerSettings')}" />

                                <TextBlock
                                    x:Name="PowerSettingsDescription"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerSettingsDescription')}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('PowerSettingsDescription')}" Visibility="{x:Bind PowerSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>

                            <Button
                                Grid.Column="2"
                                Margin="0,0,-5,0"
                                VerticalAlignment="Center"
                                Click="{x:Bind OnLearnPowerSettingsClicked}"
                                Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('LearnPowerSettings')}" />
                        </Grid>
                    </Expander.Header>

                    <StackPanel Padding="0">
                        <!--  启用休眠  -->
                        <Grid
                            Height="52"
                            Padding="44,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('EnableHibernation')}" />

                            <ToggleSwitch
                                Grid.Column="1"
                                IsEnabled="{x:Bind IsHibernationEnabled, Mode=OneWay}"
                                IsOn="{x:Bind IsHibernationOpened, Mode=OneWay}"
                                OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('EnableHibernationOffContent')}"
                                OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('EnableHibernationOnContent')}"
                                Style="{StaticResource ToggleSwitchStyle}"
                                Toggled="{x:Bind OnEnableHibernationToggled}" />
                        </Grid>

                        <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                        <!--  休眠文件类型  -->
                        <Grid
                            Height="52"
                            Padding="44,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('HibernationFileType')}" />

                            <ComboBox
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                DisplayMemberPath="DisplayMember"
                                ItemsSource="{x:Bind HibernationFileTypeList}"
                                SelectedItem="{x:Bind SelectedHibernationFileType, Mode=OneWay}"
                                SelectionChanged="{x:Bind OnHibernationFileTypeSelectionChanged}"
                                Style="{StaticResource ComboBoxStyle}" />
                        </Grid>

                        <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                        <!--  休眠文件大小  -->
                        <Grid
                            Height="52"
                            Padding="44,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            ColumnSpacing="5"
                            Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Vertical">

                                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('HibernationFileSize')}" />

                                <TextBlock
                                    x:Name="HibernationFileSizeDescription"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('HibernationFileSizeDescription')}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap">

                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('HibernationFileSizeDescription')}" Visibility="{x:Bind HibernationFileSizeDescription.IsTextTrimmed, Mode=OneWay}" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{x:Bind HibernationFileSize, Mode=OneWay}" />

                            <NumberBox
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                IsEnabled="{x:Bind x:Object.Equals(SelectedHibernationFileType, HibernationFileTypeList[1]), Mode=OneWay}"
                                LargeChange="1"
                                SmallChange="1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="{x:Bind OnHibernationFilePercentValueChanged}"
                                Value="{x:Bind HibernationFilePercent, Mode=OneWay}" />

                            <Button
                                Grid.Column="3"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="{x:Bind OnSaveHibernationFilePercentClicked}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                IsEnabled="{x:Bind x:Object.Equals(SelectedHibernationFileType, HibernationFileTypeList[1]), Mode=OneWay}"
                                ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('Save')}">

                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                            </Button>
                        </Grid>

                        <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                        <!--  快速启动  -->
                        <Grid
                            Height="52"
                            Padding="44,0,16,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('FastStartup')}" />

                            <ToggleSwitch
                                Grid.Column="1"
                                IsOn="{x:Bind IsFastStartupEnabled, Mode=OneWay}"
                                OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('FastStartupOffContent')}"
                                OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('FastStartupOnContent')}"
                                Style="{StaticResource ToggleSwitchStyle}"
                                Toggled="{x:Bind OnFastStartupToggled}" />
                        </Grid>
                    </StackPanel>
                </Expander>

                <!--  电池报告  -->
                <Grid
                    Height="60"
                    Margin="0,0,0,2"
                    Padding="16,0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="16"
                        Glyph="&#xE856;" />

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BatteryReport')}" />

                        <TextBlock
                            x:Name="BatteryReportDescription"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BatteryReportDescription')}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap">

                            <ToolTipService.ToolTip>
                                <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('BatteryReportDescription')}" Visibility="{x:Bind BatteryReportDescription.IsTextTrimmed, Mode=OneWay}" />
                            </ToolTipService.ToolTip>
                        </TextBlock>
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Click="{x:Bind OnGenerateBatteryReportClicked}"
                        Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsResource.GetString('Generate')}"
                        CornerRadius="{StaticResource ControlCornerRadius}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
