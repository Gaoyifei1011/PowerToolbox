<Page
    x:Class="PowerToolbox.Views.Pages.AdvancedSystemOptionsSystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converter="using:PowerToolbox.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:roothelper="using:PowerToolbox.Helpers.Root"
    xmlns:rootservice="using:PowerToolbox.Services.Root"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="30,0,30,0"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">

        <StackPanel Margin="0,0,0,30">

            <!--  电源设置  -->
            <Expander
                MinHeight="0"
                Margin="0,0,0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                IsExpanded="{x:Bind roothelper:RuntimeHelper.IsElevated}">

                <Expander.Header>
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xE7E8;" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerSettings')}" />

                            <TextBlock
                                x:Name="PowerSettingsDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerSettingsDescription')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerSettingsDescription')}" Visibility="{x:Bind PowerSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            Margin="0,0,-5,0"
                            VerticalAlignment="Center"
                            Click="{x:Bind OnLearnPowerSettingsClicked}"
                            Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('LearnPowerSettings')}" />
                    </Grid>
                </Expander.Header>

                <StackPanel Padding="0">
                    <!--  启用休眠  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('EnableHibernation')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsEnabled="{x:Bind IsHibernationEnabled, Mode=OneWay}"
                            IsOn="{x:Bind IsHibernationOpened, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('EnableHibernationOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('EnableHibernationOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnEnableHibernationToggled}" />
                    </Grid>

                    <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                    <!--  休眠文件类型  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('HibernationFileType')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind HibernationFileTypeList}"
                            SelectedItem="{x:Bind SelectedHibernationFileType, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnHibernationFileTypeSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                    <!--  休眠文件大小  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ColumnSpacing="5"
                        Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('HibernationFileSize')}" />

                            <TextBlock
                                x:Name="HibernationFileSizeDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('HibernationFileSizeDescription')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('HibernationFileSizeDescription')}" Visibility="{x:Bind HibernationFileSizeDescription.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{x:Bind HibernationFileSize, Mode=OneWay}" />

                        <NumberBox
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            IsEnabled="{x:Bind x:Object.Equals(SelectedHibernationFileType, HibernationFileTypeList[1]), Mode=OneWay}"
                            LargeChange="1"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            ValueChanged="{x:Bind OnHibernationFilePercentValueChanged}"
                            Value="{x:Bind HibernationFilePercent, Mode=OneWay}" />

                        <Button
                            Grid.Column="3"
                            Width="32"
                            Height="32"
                            Padding="0"
                            Click="{x:Bind OnSaveHibernationFilePercentClicked}"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            IsEnabled="{x:Bind x:Object.Equals(SelectedHibernationFileType, HibernationFileTypeList[1]), Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Save')}">

                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                        </Button>
                    </Grid>

                    <MenuFlyoutSeparator Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}" />

                    <!--  快速启动  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind IsHibernationOpened, Mode=OneWay}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('FastStartup')}" />

                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind IsFastStartupEnabled, Mode=OneWay}"
                            OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('FastStartupOffContent')}"
                            OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('FastStartupOnContent')}"
                            Style="{StaticResource ToggleSwitchStyle}"
                            Toggled="{x:Bind OnFastStartupToggled}" />
                    </Grid>
                </StackPanel>
            </Expander>

            <!--  电源模式设置  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xE945;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerModeSettings')}" />

                    <TextBlock
                        x:Name="PowerModeSettingsDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerModeSettingsDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('PowerModeSettingsDescription')}" Visibility="{x:Bind PowerModeSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Margin="0,0,6,0"
                    Padding="0"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('ShowOptions')}">

                    <FontIcon FontSize="14" Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnOpenSystemPowerSettingsClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('OpenSystemSettings')}">
                                <MenuFlyoutItem.Icon>
                                    <AnimatedIcon>
                                        <AnimatedIcon.Source>
                                            <animatedvisuals:AnimatedSettingsVisualSource />
                                        </AnimatedIcon.Source>
                                        <AnimatedIcon.FallbackIconSource>
                                            <FontIconSource Glyph="&#xE713;" />
                                        </AnimatedIcon.FallbackIconSource>
                                    </AnimatedIcon>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Click="{x:Bind OnOpenControlPanelClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('OpenControlPanel')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70A;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button
                    Grid.Column="3"
                    Width="32"
                    Height="32"
                    Padding="8"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Change')}">

                    <AnimatedIcon>
                        <AnimatedIcon.Source>
                            <animatedvisuals:AnimatedChevronDownSmallVisualSource />
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <FontIconSource Glyph="&#xE70D;" />
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem
                                Click="{x:Bind OnChangePowerModeClicked}"
                                Tag="EnergySaving"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('EnergySaving')}" />

                            <MenuFlyoutItem
                                Click="{x:Bind OnChangePowerModeClicked}"
                                Tag="Balance"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Balance')}" />

                            <MenuFlyoutItem
                                Click="{x:Bind OnChangePowerModeClicked}"
                                Tag="HighPerformance"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('HighPerformance')}" />

                            <MenuFlyoutItem
                                Click="{x:Bind OnChangePowerModeClicked}"
                                Tag="OutstandingPerformance"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('OutstandingPerformance')}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!--  电池报告  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xE856;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BatteryReport')}" />

                    <TextBlock
                        x:Name="BatteryReportDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BatteryReportDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BatteryReportDescription')}" Visibility="{x:Bind BatteryReportDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Click="{x:Bind OnGenerateBatteryReportClicked}"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid>
                        <TextBlock Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Generate')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsGeneratingBatteryReport), Mode=OneWay}" />

                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind IsGeneratingBatteryReport, Mode=OneWay}"
                            Visibility="{x:Bind IsGeneratingBatteryReport, Mode=OneWay}" />
                    </Grid>
                </Button>
            </Grid>

            <!--  用户账户控制设置  -->
            <Expander
                Margin="0,0,0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                IsExpanded="{x:Bind roothelper:RuntimeHelper.IsElevated}">

                <Expander.Header>
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xF0EF;" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('UACSettings')}" />

                            <TextBlock
                                x:Name="UACSettingsDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('UACSettingsDescription')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('UACSettingsDescription')}" Visibility="{x:Bind UACSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Expander.Header>

                <StackPanel Padding="0">
                    <!--  用户账户控制通知模式  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyMode')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind NotifyModeList}"
                            SelectedItem="{x:Bind SelectedNotifyMode, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnNotifyModeSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!--  用户账户控制通知模式说明  -->
                    <Grid Padding="44,5,16,8">
                        <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[0].SelectedValue), Mode=OneWay}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                FontSize="16"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('AlwaysNotify')}" />

                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('AlwaysNotifyDescription1')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="2"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('AlwaysNotifyDescription2')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('AlwaysNotifyDescription3')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="4"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('AlwaysNotifyDescription4')}"
                                TextWrapping="Wrap" />
                        </Grid>

                        <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[1].SelectedValue), Mode=OneWay}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                FontSize="16"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Notify')}" />

                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyDescription1')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="2"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyDescription2')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyDescription3')}"
                                TextWrapping="Wrap" />
                        </Grid>

                        <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[2].SelectedValue), Mode=OneWay}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                FontSize="16"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyWithoutDimming')}" />

                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyWithoutDimmingDescription1')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="2"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyWithoutDimmingDescription2')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NotifyWithoutDimmingDescription3')}"
                                TextWrapping="Wrap" />
                        </Grid>

                        <Grid RowSpacing="3" Visibility="{x:Bind GetSelectedNotifyMode(SelectedNotifyMode.SelectedValue, NotifyModeList[3].SelectedValue), Mode=OneWay}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                FontSize="16"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NeverNotify')}" />

                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NeverNotifyDescription1')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="2"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NeverNotifyDescription2')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NeverNotifyDescription3')}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="4"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NeverNotifyDescription4')}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Expander>

            <!--  后台应用设置  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xEF1F;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BackgroundAppsSettings')}" />

                    <TextBlock
                        x:Name="BackgroundAppsSettingsDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BackgroundAppsSettingsDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BackgroundAppsSettingsDescription')}" Visibility="{x:Bind PowerModeSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <ToggleSwitch
                    Grid.Column="2"
                    IsOn="{x:Bind IsBackgroundAppsTaskEnabled, Mode=OneWay}"
                    OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BackgroundAppsSettingsOffContent')}"
                    OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('BackgroundAppsSettingsOnContent')}"
                    Style="{StaticResource ToggleSwitchStyle}"
                    Toggled="{x:Bind OnBackgroundAppsTaskToggled}" />
            </Grid>

            <!--  系统保留存储  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xEDA2;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('SystemReservedStorage')}" />

                    <TextBlock
                        x:Name="SystemReservedStorageDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('SystemReservedStorageDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('SystemReservedStorageDescription')}" Visibility="{x:Bind SystemReservedStorageDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Margin="0,0,6,0"
                    Padding="0"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('ShowOptions')}">

                    <FontIcon FontSize="14" Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnOpenSystemStorageSettingsClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('OpenSystemSettings')}">
                                <MenuFlyoutItem.Icon>
                                    <AnimatedIcon>
                                        <AnimatedIcon.Source>
                                            <animatedvisuals:AnimatedSettingsVisualSource />
                                        </AnimatedIcon.Source>
                                        <AnimatedIcon.FallbackIconSource>
                                            <FontIconSource Glyph="&#xE713;" />
                                        </AnimatedIcon.FallbackIconSource>
                                    </AnimatedIcon>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Click="{x:Bind OnLearnSystemReservedStorageClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('LearnSystemReservedStorage')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE890;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <ProgressRing
                    Grid.Column="3"
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0"
                    IsActive="{x:Bind IsSystemReservedStorageLoadingOrUpdating, Mode=OneWay}"
                    Visibility="{x:Bind IsSystemReservedStorageLoadingOrUpdating, Mode=OneWay}" />

                <ToggleSwitch
                    Grid.Column="4"
                    IsEnabled="{x:Bind converter:ValueConverterHelper.BooleanReverseConvert(IsSystemReservedStorageLoadingOrUpdating), Mode=OneWay}"
                    IsOn="{x:Bind IsSystemReservedStorageEnabled, Mode=OneWay}"
                    OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('SystemReservedStorageOffContent')}"
                    OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('SystemReservedStorageOnContent')}"
                    Style="{StaticResource ToggleSwitchStyle}"
                    Toggled="{x:Bind OnSystemReservedStorageToggled}" />
            </Grid>

            <!--  基于虚拟化的安全  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xE964;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('VirtualizationBasedSecurity')}" />

                    <TextBlock
                        x:Name="VirtualizationBasedSecurityDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('VirtualizationBasedSecurityDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('VirtualizationBasedSecurityDescription')}" Visibility="{x:Bind VirtualizationBasedSecurityDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Margin="0,0,6,0"
                    Padding="0"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('ShowOptions')}">

                    <FontIcon FontSize="14" Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnLearnVBSClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('LearnVBS')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE890;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <ToggleSwitch
                    Grid.Column="3"
                    IsOn="{x:Bind IsVirtualizationBasedSecurityEnabled, Mode=OneWay}"
                    OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('VirtualizationBasedSecurityOffContent')}"
                    OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('VirtualizationBasedSecurityOnContent')}"
                    Style="{StaticResource ToggleSwitchStyle}"
                    Toggled="{x:Bind OnVirtualizationBasedSecurityToggled}" />
            </Grid>

            <!--  网卡负载设置  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xEDA3;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NICOffloadSettings')}" />

                    <TextBlock
                        x:Name="NICOffloadSettingsDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NICOffloadSettingsDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NICOffloadSettingsDescription')}" Visibility="{x:Bind NICOffloadSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Margin="0,0,6,0"
                    Padding="0"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('ShowOptions')}">

                    <FontIcon FontSize="14" Glyph="&#xE712;" />

                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="{x:Bind OnLearnNICOffloadClicked}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('LearnNICOffload')}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE890;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <ToggleSwitch
                    Grid.Column="3"
                    IsOn="{x:Bind IsNICOffloadSettingsEnabled, Mode=OneWay}"
                    OffContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NICOffloadSettingsOffContent')}"
                    OnContent="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('NICOffloadSettingsOnContent')}"
                    Style="{StaticResource ToggleSwitchStyle}"
                    Toggled="{x:Bind OnNICOffloadSettingsToggled}" />
            </Grid>

            <!--  关闭唤醒任务  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xE708;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('CloseWakeUpTask')}" />

                    <TextBlock
                        x:Name="CloseWakeUpTaskDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('CloseWakeUpTaskDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('CloseWakeUpTaskDescription')}" Visibility="{x:Bind CloseWakeUpTaskDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <InfoBadge
                    Grid.Column="2"
                    Style="{StaticResource InformationalValueInfoBadgeStyle}"
                    ToolTipService.ToolTip="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('WakeUpTaskEmpty')}"
                    Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityReverseConvert(WakeUpTaskCollection.Count), Mode=OneWay}"
                    Value="{x:Bind WakeUpTaskCollection.Count, Mode=OneWay}" />

                <InfoBadge
                    Grid.Column="2"
                    Style="{StaticResource CautionValueInfoBadgeStyle}"
                    Visibility="{x:Bind converter:ValueConverterHelper.IntToVisibilityConvert(WakeUpTaskCollection.Count), Mode=OneWay}"
                    Value="{x:Bind WakeUpTaskCollection.Count, Mode=OneWay}">

                    <ToolTipService.ToolTip>
                        <ToolTip>
                            <StackPanel>
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('WaskUpTaskExisted')}" />

                                <ListView ItemsSource="{x:Bind WakeUpTaskCollection}">
                                    <ListView.ItemContainerStyle>
                                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                            <Setter Property="MinHeight" Value="0" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <Setter Property="FontSize" Value="12" />
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ItemsControl.ItemContainerTransitions>
                                        <TransitionCollection />
                                    </ItemsControl.ItemContainerTransitions>
                                </ListView>
                            </StackPanel>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                </InfoBadge>

                <Button
                    Grid.Column="3"
                    Margin="5,0,0,0"
                    Click="{x:Bind OnCloseWakeUpTaskClicked}"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid>
                        <TextBlock Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Close')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsClosingWakeUpTask), Mode=OneWay}" />

                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind IsClosingWakeUpTask, Mode=OneWay}"
                            Visibility="{x:Bind IsClosingWakeUpTask, Mode=OneWay}" />
                    </Grid>
                </Button>
            </Grid>

            <!--  重启显卡驱动  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xE7F4;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('RestartGraphicsDriver')}" />

                    <TextBlock
                        x:Name="RestartGraphicsDriverDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('RestartGraphicsDriverDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('RestartGraphicsDriverDescription')}" Visibility="{x:Bind RestartGraphicsDriverDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Click="{x:Bind OnRestartGraphicsDriverClicked}"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid>
                        <TextBlock Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsSystemResource.GetString('Restart')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsRestartingGraphicsDriver), Mode=OneWay}" />

                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind IsRestartingGraphicsDriver, Mode=OneWay}"
                            Visibility="{x:Bind IsRestartingGraphicsDriver, Mode=OneWay}" />
                    </Grid>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
