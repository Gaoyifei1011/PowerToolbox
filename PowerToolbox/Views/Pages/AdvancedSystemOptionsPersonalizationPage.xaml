<Page
    x:Class="PowerToolbox.Views.Pages.AdvancedSystemOptionsPersonalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:class="using:PowerToolbox.Extensions.DataType.Class"
    xmlns:converter="using:PowerToolbox.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enum="using:PowerToolbox.Extensions.DataType.Enums"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:PowerToolbox.Models"
    xmlns:roothelper="using:PowerToolbox.Helpers.Root"
    xmlns:rootservice="using:PowerToolbox.Services.Root"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <class:ExecuteCommand x:Name="DesktopIconDisplayCommand" ExecuteRequested="{x:Bind OnDesktopIconDisplayExecuteRequested}" />
    </Page.Resources>

    <ScrollViewer
        Padding="30,0,30,0"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Enabled">

        <StackPanel Margin="0,0,0,30">

            <!--  重建图标缓存  -->
            <Grid
                Height="60"
                Margin="0,0,0,2"
                Padding="16,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="16"
                    Glyph="&#xED58;" />

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('RebuildIconCache')}" />

                    <TextBlock
                        x:Name="RebuildIconCacheDescription"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('RebuildIconCacheDescription')}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap">

                        <ToolTipService.ToolTip>
                            <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('RebuildIconCacheDescription')}" Visibility="{x:Bind RebuildIconCacheDescription.IsTextTrimmed, Mode=OneWay}" />
                        </ToolTipService.ToolTip>
                    </TextBlock>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Click="{x:Bind OnRebuildIconCacheClicked}"
                    CornerRadius="{StaticResource ControlCornerRadius}">

                    <Grid>
                        <TextBlock Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('Rebuild')}" Visibility="{x:Bind converter:ValueConverterHelper.BooleanToVisibilityReverseConvert(IsRebuildingIconCache), Mode=OneWay}" />

                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{x:Bind IsRebuildingIconCache, Mode=OneWay}"
                            Visibility="{x:Bind IsRebuildingIconCache, Mode=OneWay}" />
                    </Grid>
                </Button>
            </Grid>

            <!--  桌面设置  -->
            <Expander
                MinHeight="0"
                Margin="0,0,0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                IsExpanded="{x:Bind roothelper:RuntimeHelper.IsElevated}">

                <Expander.Header>
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xE70A;" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('DesktopSettings')}" />

                            <TextBlock
                                x:Name="DesktopSettingsDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('DesktopSettingsDescription')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('DesktopSettingsDescription')}" Visibility="{x:Bind DesktopSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Expander.Header>

                <StackPanel Padding="0">
                    <!--  修改桌面图标  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('ChangeDesktopIcon')}" />

                        <Button
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            Click="{x:Bind OnChangeDesktopIconClicked}"
                            Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('Change')}"
                            IsEnabled="{x:Bind IsIconSelected, Mode=OneWay}" />

                        <Button
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            Click="{x:Bind OnRestoreDefualtIconClicked}"
                            Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('RestoreDefualtIcon')}"
                            IsEnabled="{x:Bind IsIconSelected, Mode=OneWay}" />
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!--  对应的桌面图标  -->
                    <GridView
                        x:Name="DesktopIconSettingsGridView"
                        Padding="44,5,16,0"
                        ItemsSource="{x:Bind DesktopIconSettingsCollection}"
                        SelectedItem="{x:Bind SelectedIconItem, Mode=OneWay}"
                        SelectionChanged="{x:Bind OnIconSelectionChanged}"
                        SelectionMode="Single">

                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="model:DesktopIconSettingsModel">
                                <Grid
                                    Width="90"
                                    Padding="0,8"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ControlCornerRadius}">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid
                                        Grid.Row="0"
                                        Width="72"
                                        Margin="0,10"
                                        CornerRadius="{ThemeResource ControlCornerRadius}">
                                        <Image
                                            Width="48"
                                            HorizontalAlignment="Center"
                                            Source="{x:Bind IconImage, Mode=OneWay}"
                                            Stretch="Uniform" />
                                    </Grid>

                                    <TextBlock
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        FontSize="12"
                                        Text="{x:Bind DisplayName}"
                                        TextLineBounds="TrimToCapHeight"
                                        TextWrapping="NoWrap" />
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>

                        <GridView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,6,6" />
                            </Style>
                        </GridView.ItemContainerStyle>
                    </GridView>

                    <MenuFlyoutSeparator />

                    <!--  桌面图标显示  -->
                    <Grid
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ColumnSpacing="5">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('DesktopIconDisplay')}" />

                        <GridView
                            Grid.Column="1"
                            ItemsSource="{x:Bind DesktopIconDisplayCollection}"
                            SelectionMode="None">

                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>

                            <GridView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>

                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="model:DesktopIconDisplayModel">
                                    <CheckBox
                                        Command="{StaticResource DesktopIconDisplayCommand}"
                                        CommandParameter="{x:Bind}"
                                        Content="{x:Bind DisplayName}"
                                        IsChecked="{x:Bind IsIconVisible, Mode=OneWay}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!--  桌面快捷箭头  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('DesktopShortcutArrow')}" />

                        <Button
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            Click="{x:Bind OnShowDesktopShortcutArrowClicked}"
                            Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('Show')}" />

                        <Button
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            Click="{x:Bind OnHideDesktopShortcutArrowClicked}"
                            Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('Hide')}" />
                    </Grid>
                </StackPanel>
            </Expander>

            <!--  文件资源管理器设置  -->
            <Expander
                MinHeight="0"
                Margin="0,0,0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                IsExpanded="{x:Bind roothelper:RuntimeHelper.IsElevated}">

                <Expander.Header>
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,12,0"
                            FontSize="16"
                            Glyph="&#xE8FC;" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Vertical">

                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('FileExplorerSettings')}" />

                            <TextBlock
                                x:Name="FileExplorerSettingsDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('FileExplorerSettingsDescription')}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap">

                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('FileExplorerSettingsDescription')}" Visibility="{x:Bind FileExplorerSettingsDescription.IsTextTrimmed, Mode=OneWay}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Expander.Header>

                <StackPanel Padding="0">

                    <!--  右键菜单样式  -->
                    <Grid
                        Height="52"
                        Padding="44,0,16,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind roothelper:RuntimeHelper.IsWindows11}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="{x:Bind rootservice:ResourceService.AdvancedSystemOptionsPersonalizationResource.GetString('RightClickMenuStyle')}" />

                        <ComboBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            DisplayMemberPath="DisplayMember"
                            ItemsSource="{x:Bind RightClickMenuStyleList}"
                            SelectedItem="{x:Bind RightClickMenuStyle, Mode=OneWay}"
                            SelectionChanged="{x:Bind OnRightClickMenuStyleSelectionChanged}"
                            Style="{StaticResource ComboBoxStyle}" />
                    </Grid>

                    <MenuFlyoutSeparator Visibility="{x:Bind roothelper:RuntimeHelper.IsWindows11}" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
